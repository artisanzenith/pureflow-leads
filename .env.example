# Site URL (required for production SEO, sitemap, canonical URLs)
NEXT_PUBLIC_SITE_URL=https://thepureflowleads.com

# Newsletter provider (e.g. ConvertKit, Mailchimp, Resend)
# NEWSLETTER_API_KEY=
# NEWSLETTER_LIST_ID=

# Contact form handler (e.g. Resend, Formspree, SendGrid)
# CONTACT_FORM_ENDPOINT=
# CONTACT_EMAIL=hello@thepureflowleads.com

# Analytics
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google AdSense (when approved)
# NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-xxxxxxxx

# Affiliate tracking (optional)
# NEXT_PUBLIC_AFFILIATE_DISCLOSURE=true
